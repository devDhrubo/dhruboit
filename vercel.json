{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "installCommand": "npm install --no-audit --no-fund --loglevel=error",
  "outputDirectory": ".vercel/output",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
